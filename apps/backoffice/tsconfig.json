{
  "extends": "@flower/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@flower/api-client": ["../../packages/api-client/src"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "app/**/*", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
