enum TransferStatus {
  DRAFT
  DISPATCHED
  RECEIVED
  CANCELLED
  REVERSED
}

enum TransferTimelineEventType {
  TRANSFER_CREATED
  TRANSFER_DISPATCHED
  TRANSFER_RECEIVED
  TRANSFER_CANCELLED
  TRANSFER_REVERSED
}

model TransferDocument {
  id                    String         @id @default(uuid()) @db.Uuid
  organizationId        String         @map("organization_id") @db.Uuid
  storeId               String         @map("store_id") @db.Uuid
  fromWarehouseId       String         @map("from_warehouse_id") @db.Uuid
  toWarehouseId         String         @map("to_warehouse_id") @db.Uuid
  number                String
  status                TransferStatus @default(DRAFT)
  version               Int            @default(1)
  dispatchedAt          DateTime?      @map("dispatched_at")
  receivedAt            DateTime?      @map("received_at")
  cancelledAt           DateTime?      @map("cancelled_at")
  reversedAt            DateTime?      @map("reversed_at")
  comment               String?
  createdByMembershipId String?        @map("created_by_membership_id") @db.Uuid
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  fromWarehouse Warehouse              @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse              @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  items         TransferItem[]
  allocations   TransferAllocation[]
  timeline      TransferTimelineEvent[]

  @@unique([organizationId, number])
  @@index([organizationId, storeId])
  @@index([organizationId, fromWarehouseId])
  @@index([organizationId, toWarehouseId])
  @@index([organizationId, status])
  @@map("transfer_documents")
}

model TransferItem {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  transferDocumentId String   @map("transfer_document_id") @db.Uuid
  itemId             String   @map("item_id") @db.Uuid
  requestedQuantity  Decimal  @map("requested_quantity") @db.Decimal(18, 3)
  dispatchedQuantity Decimal? @map("dispatched_quantity") @db.Decimal(18, 3)
  receivedQuantity   Decimal? @map("received_quantity") @db.Decimal(18, 3)
  damagedQuantity    Decimal? @map("damaged_quantity") @db.Decimal(18, 3)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transferDocument TransferDocument @relation(fields: [transferDocumentId], references: [id], onDelete: Restrict)
  item             Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  allocations      TransferAllocation[]

  @@index([organizationId])
  @@index([transferDocumentId])
  @@index([itemId])
  @@map("transfer_items")
}

model TransferAllocation {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  transferDocumentId String   @map("transfer_document_id") @db.Uuid
  transferItemId     String   @map("transfer_item_id") @db.Uuid
  fromItemId         String   @map("from_item_id") @db.Uuid
  batchId            String   @map("batch_id") @db.Uuid
  quantityDispatched Decimal  @map("quantity_dispatched") @db.Decimal(18, 3)
  quantityReceived   Decimal? @map("quantity_received") @db.Decimal(18, 3)
  quantityDamaged    Decimal? @map("quantity_damaged") @db.Decimal(18, 3)
  unitCost           Decimal  @map("unit_cost") @db.Decimal(18, 4)
  toItemId           String?  @map("to_item_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transferDocument TransferDocument @relation(fields: [transferDocumentId], references: [id], onDelete: Restrict)
  transferItem     TransferItem     @relation(fields: [transferItemId], references: [id], onDelete: Restrict)
  fromItem         Item             @relation("TransferAllocationFromItem", fields: [fromItemId], references: [id], onDelete: Restrict)
  toItem           Item?            @relation("TransferAllocationToItem", fields: [toItemId], references: [id], onDelete: Restrict)
  batch            InventoryBatch   @relation("TransferSourceBatch", fields: [batchId], references: [id], onDelete: Restrict)
  createdBatch     InventoryBatch? @relation("TransferInboundBatch")

  @@index([organizationId])
  @@index([transferDocumentId])
  @@index([transferItemId])
  @@index([batchId])
  @@map("transfer_allocations")
}

model TransferTimelineEvent {
  id                 String                    @id @default(uuid()) @db.Uuid
  organizationId     String                    @map("organization_id") @db.Uuid
  transferDocumentId String                    @map("transfer_document_id") @db.Uuid
  type               TransferTimelineEventType
  message            String?
  actorMembershipId  String?                   @map("actor_membership_id") @db.Uuid
  payload            Json?
  occurredAt         DateTime                  @map("occurred_at")
  createdAt          DateTime                  @default(now()) @map("created_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transferDocument TransferDocument @relation(fields: [transferDocumentId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([transferDocumentId, occurredAt])
  @@map("transfer_timeline_events")
}

// ─── Sales bounded context (owned by sales module) — ADR-016/017/018 ─────────

enum SaleType {
  ORDER_BASED
  DIRECT
}

enum SaleStatus {
  DRAFT
  COMPLETED
  ANNULLED
}

enum SalesChannel {
  STORE
  PHONE
  WEBSITE
  TELEGRAM
  OTHER
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}

enum DiscountReason {
  PROMOTION
  LOYAL_CUSTOMER
  AGED_FLOWERS
  MANAGER_DECISION
  OTHER
}

enum SaleInventorySourceType {
  ORDER_ACTUAL_COMPOSITION
  DIRECT_COMPOSITION
}

enum SaleTimelineEventType {
  SALE_CREATED
  SALE_COMPLETED
  SALE_ANNULLED
  DISCOUNT_APPLIED
  INVENTORY_ISSUED
  INVENTORY_REVERSED
  PAYMENT_RECEIVED
  PAYMENT_STATUS_CHANGED
