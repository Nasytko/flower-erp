model Sale {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  storeId            String       @map("store_id") @db.Uuid
  warehouseId        String       @map("warehouse_id") @db.Uuid
  orderId            String?      @map("order_id") @db.Uuid
  number             String
  type               SaleType
  status             SaleStatus   @default(DRAFT)
  salesChannel       SalesChannel @default(STORE) @map("sales_channel")
  grossAmount        Decimal      @map("gross_amount") @db.Decimal(18, 2)
  discountAmount     Decimal      @default(0) @map("discount_amount") @db.Decimal(18, 2)
  netAmount          Decimal      @map("net_amount") @db.Decimal(18, 2)
  costAmount         Decimal?     @map("cost_amount") @db.Decimal(18, 4)
  grossProfitAmount  Decimal?     @map("gross_profit_amount") @db.Decimal(18, 4)
  marginPercent      Decimal?     @map("margin_percent") @db.Decimal(9, 4)
  currencyCode       String       @default("BYN") @map("currency_code")
  comment            String?
  completedAt        DateTime?    @map("completed_at")
  annulledAt         DateTime?    @map("annulled_at")
  createdByMembershipId String?   @map("created_by_membership_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lines        SaleLine[]
  discount     SaleDiscount?
  consumption  SaleInventoryConsumption?
  timeline     SaleTimelineEvent[]
  annulment    SaleAnnulment?

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, storeId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, completedAt])
  @@index([orderId])
  @@map("sales")
}

model SaleLine {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  saleId               String   @map("sale_id") @db.Uuid
  itemId               String?  @map("item_id") @db.Uuid
  descriptionSnapshot  String   @map("description_snapshot")
  quantity             Decimal  @db.Decimal(18, 3)
  unitPrice            Decimal  @map("unit_price") @db.Decimal(18, 2)
  grossAmount          Decimal  @map("gross_amount") @db.Decimal(18, 2)
  discountAmount       Decimal  @default(0) @map("discount_amount") @db.Decimal(18, 2)
  netAmount            Decimal  @map("net_amount") @db.Decimal(18, 2)
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([saleId])
  @@map("sale_lines")
}

model SaleDiscount {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  saleId         String         @unique @map("sale_id") @db.Uuid
  type           DiscountType   @default(NONE)
  value          Decimal        @default(0) @db.Decimal(18, 4)
  reason         DiscountReason @default(OTHER)
  comment        String?
  approvedByMembershipId String? @map("approved_by_membership_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@map("sale_discounts")
}

model SaleInventoryConsumption {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  saleId         String                  @unique @map("sale_id") @db.Uuid
  sourceType     SaleInventorySourceType @map("source_type")
  createdAt      DateTime                @default(now()) @map("created_at")

  organization Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sale         Sale                           @relation(fields: [saleId], references: [id], onDelete: Restrict)
  lines        SaleInventoryConsumptionLine[]

  @@index([organizationId])
  @@map("sale_inventory_consumptions")
}

model SaleInventoryConsumptionLine {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  consumptionId      String   @map("consumption_id") @db.Uuid
  itemId             String   @map("item_id") @db.Uuid
  requestedQuantity  Decimal  @map("requested_quantity") @db.Decimal(18, 3)
  issuedQuantity     Decimal  @map("issued_quantity") @db.Decimal(18, 3)
  costAmount         Decimal  @map("cost_amount") @db.Decimal(18, 4)
  createdAt          DateTime @default(now()) @map("created_at")

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  consumption  SaleInventoryConsumption @relation(fields: [consumptionId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([consumptionId])
  @@index([itemId])
  @@map("sale_inventory_consumption_lines")
}

model SaleTimelineEvent {
  id                  String                @id @default(uuid()) @db.Uuid
  organizationId      String                @map("organization_id") @db.Uuid
  saleId              String                @map("sale_id") @db.Uuid
  type                SaleTimelineEventType
  message             String?
  actorMembershipId   String?               @map("actor_membership_id") @db.Uuid
  payload             Json?
  occurredAt          DateTime              @map("occurred_at")
  createdAt           DateTime              @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([saleId, occurredAt])
  @@map("sale_timeline_events")
}

model SaleAnnulment {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  saleId              String   @unique @map("sale_id") @db.Uuid
  reason              String
  actorMembershipId   String?  @map("actor_membership_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@map("sale_annulments")
}

// ─── Payments & Cash (owned by payments module) ───────────────────────────────

enum PaymentMethodType {
  CASH
  BANK_CARD
  ONLINE
  QR
  BANK_TRANSFER
  GIFT_CERTIFICATE
  OTHER
}

enum PaymentType {
  ORDER_PREPAYMENT
  SALE_PAYMENT
  REFUND
  MANUAL_ADJUSTMENT
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentStatus {
  DRAFT
  COMPLETED
  ANNULLED
}

enum PaymentAllocationTargetType {
  ORDER
  SALE
}

enum PaymentRefundStatus {
  DRAFT
  COMPLETED
  ANNULLED
}

enum PaymentTimelineEventType {
  PAYMENT_CREATED
  PAYMENT_COMPLETED
  PAYMENT_ANNULLED
  PAYMENT_ALLOCATED_TO_ORDER
  PAYMENT_ALLOCATED_TO_SALE
  PREPAYMENT_TRANSFERRED
  REFUND_CREATED
  REFUND_COMPLETED
  REFUND_ANNULLED
}

enum CashAccountType {
  CASH_REGISTER
  BANK
  OTHER
}

enum CashAccountStatus {
  ACTIVE
  ARCHIVED
}

enum CashOperationType {
  PAYMENT_RECEIPT
  REFUND_PAYMENT
  MANUAL_INCOME
  MANUAL_EXPENSE
  PAYMENT_ANNULMENT_REVERSAL
}

enum CashOperationDirection {
  IN
  OUT
}

model PaymentMethod {
  id                            String            @id @default(uuid()) @db.Uuid
  organizationId                String            @map("organization_id") @db.Uuid
  code                          String
  name                          String
  type                          PaymentMethodType
  isActive                      Boolean           @default(true) @map("is_active")
  requiresExternalConfirmation  Boolean           @default(false) @map("requires_external_confirmation")
  sortOrder                     Int               @default(0) @map("sort_order")
  createdAt                     DateTime          @default(now()) @map("created_at")
  updatedAt                     DateTime          @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  payments     Payment[]
  refunds      PaymentRefund[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive, sortOrder])
  @@map("payment_methods")
}

model Payment {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  storeId           String           @map("store_id") @db.Uuid
  number            String
  type              PaymentType
  status            PaymentStatus    @default(DRAFT)
  direction         PaymentDirection
  methodId          String           @map("method_id") @db.Uuid
  amount            Decimal          @db.Decimal(19, 4)
  currencyCode      String           @default("BYN") @map("currency_code") @db.Char(3)
  receivedAt        DateTime         @map("received_at")
  comment           String?
  externalReference String?          @map("external_reference")
  createdByMembershipId String?      @map("created_by_membership_id") @db.Uuid
  completedAt       DateTime?        @map("completed_at")
  annulledAt        DateTime?        @map("annulled_at")
  annulReason       String?          @map("annul_reason")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  method       PaymentMethod        @relation(fields: [methodId], references: [id], onDelete: Restrict)
  allocations  PaymentAllocation[]
  refunds      PaymentRefund[]
  timelineEvents PaymentTimelineEvent[]
  cashOperations CashOperation[]
  allocationTransfers PaymentAllocationTransfer[]

  @@unique([organizationId, number])
  @@index([organizationId, storeId, status])
  @@index([organizationId, storeId, receivedAt])
  @@index([methodId])
  @@map("payments")
}

model PaymentAllocation {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  paymentId      String                       @map("payment_id") @db.Uuid
  targetType     PaymentAllocationTargetType  @map("target_type")
  targetId       String                       @map("target_id") @db.Uuid
  amount         Decimal                      @db.Decimal(19, 4)
  isActive       Boolean                      @default(true) @map("is_active")
  supersededAt   DateTime?                    @map("superseded_at")
  createdAt      DateTime                     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  transfersFrom PaymentAllocationTransfer[] @relation("TransferFromAllocation")
  transfersTo   PaymentAllocationTransfer[] @relation("TransferToAllocation")

  @@index([organizationId, paymentId])
  @@index([organizationId, targetType, targetId, isActive])
  @@map("payment_allocations")
}

model PaymentAllocationTransfer {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  paymentId            String   @map("payment_id") @db.Uuid
  fromAllocationId     String   @map("from_allocation_id") @db.Uuid
  toAllocationId       String   @map("to_allocation_id") @db.Uuid
  amount               Decimal  @db.Decimal(19, 4)
  fromTargetType       PaymentAllocationTargetType @map("from_target_type")
  fromTargetId         String   @map("from_target_id") @db.Uuid
  toTargetType         PaymentAllocationTargetType @map("to_target_type")
  toTargetId           String   @map("to_target_id") @db.Uuid
  actorMembershipId    String?  @map("actor_membership_id") @db.Uuid
  occurredAt           DateTime @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  payment        Payment           @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  fromAllocation PaymentAllocation @relation("TransferFromAllocation", fields: [fromAllocationId], references: [id], onDelete: Restrict)
  toAllocation   PaymentAllocation @relation("TransferToAllocation", fields: [toAllocationId], references: [id], onDelete: Restrict)

  @@index([organizationId, paymentId])
  @@index([fromTargetType, fromTargetId])
  @@index([toTargetType, toTargetId])
  @@map("payment_allocation_transfers")
}

model PaymentRefund {
  id                    String              @id @default(uuid()) @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  storeId               String              @map("store_id") @db.Uuid
  originalPaymentId     String              @map("original_payment_id") @db.Uuid
  amount                Decimal             @db.Decimal(19, 4)
  reason                String
  status                PaymentRefundStatus @default(DRAFT)
  methodId              String              @map("method_id") @db.Uuid
  externalReference     String?             @map("external_reference")
  createdByMembershipId String?             @map("created_by_membership_id") @db.Uuid
  completedAt           DateTime?           @map("completed_at")
  annulledAt            DateTime?           @map("annulled_at")
  annulReason           String?             @map("annul_reason")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  originalPayment Payment       @relation(fields: [originalPaymentId], references: [id], onDelete: Restrict)
  method          PaymentMethod @relation(fields: [methodId], references: [id], onDelete: Restrict)
  cashOperations  CashOperation[]

  @@index([organizationId, storeId, status])
  @@index([originalPaymentId, status])
  @@map("payment_refunds")
}

model PaymentTimelineEvent {
  id                String                    @id @default(uuid()) @db.Uuid
  organizationId    String                    @map("organization_id") @db.Uuid
  paymentId         String                    @map("payment_id") @db.Uuid
  type              PaymentTimelineEventType
  message           String?
  actorMembershipId String?                   @map("actor_membership_id") @db.Uuid
  payload           Json?
  occurredAt        DateTime                  @map("occurred_at")
  createdAt         DateTime                  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([paymentId, occurredAt])
  @@map("payment_timeline_events")
}

model CashAccount {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  storeId        String            @map("store_id") @db.Uuid
  name           String
  type           CashAccountType
  status         CashAccountStatus @default(ACTIVE)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  operations   CashOperation[]

  @@index([organizationId, storeId, status])
  @@map("cash_accounts")
}

model CashOperation {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @map("organization_id") @db.Uuid
  storeId           String                 @map("store_id") @db.Uuid
  cashAccountId     String                 @map("cash_account_id") @db.Uuid
  paymentId         String?                @map("payment_id") @db.Uuid
  refundId          String?                @map("refund_id") @db.Uuid
  type              CashOperationType
  direction         CashOperationDirection
  amount            Decimal                @db.Decimal(19, 4)
  occurredAt        DateTime               @map("occurred_at")
  comment           String?
  createdByMembershipId String?            @map("created_by_membership_id") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cashAccount  CashAccount  @relation(fields: [cashAccountId], references: [id], onDelete: Restrict)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  refund       PaymentRefund? @relation(fields: [refundId], references: [id], onDelete: Restrict)

  @@index([organizationId, storeId, occurredAt])
  @@index([cashAccountId, occurredAt])
  @@index([paymentId])
  @@index([refundId])
  @@map("cash_operations")
}

// ─── Identity & Access (owned by identity/auth modules) ──────────────────────

enum UserStatus {
  ACTIVE
  BLOCKED
  ARCHIVED
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum RoleStatus {
  ACTIVE
  ARCHIVED
}

enum StoreAccessMode {
  ALL_STORES
  SELECTED_STORES
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  login               String     @unique
  email               String?
  passwordHash        String     @map("password_hash")
  displayName         String     @map("display_name")
  status              UserStatus @default(ACTIVE)
  passwordChangedAt   DateTime   @map("password_changed_at")
  mustChangePassword  Boolean    @default(false) @map("must_change_password")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  memberships OrganizationMembership[]
  sessions    Session[]

  @@index([status])
  @@map("users")
}

model OrganizationMembership {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  status          MembershipStatus @default(ACTIVE)
  storeAccessMode StoreAccessMode  @default(ALL_STORES) @map("store_access_mode")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles        MembershipRole[]
  storeAccess  UserStoreAccess[]
  sessions     Session[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, status])
  @@map("organization_memberships")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique
  description String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String
  code           String
  isSystem       Boolean    @default(false) @map("is_system")
  status         RoleStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  permissions     RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model MembershipRole {
  membershipId String @map("membership_id") @db.Uuid
  roleId       String @map("role_id") @db.Uuid

  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  role       Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([membershipId, roleId])
  @@map("membership_roles")
}

model UserStoreAccess {
  id           String   @id @default(uuid()) @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  store      Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([membershipId, storeId])
  @@index([membershipId])
  @@index([storeId])
  @@map("user_store_access")
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  membershipId     String        @map("membership_id") @db.Uuid
  familyId         String        @map("family_id") @db.Uuid
  refreshTokenHash String        @map("refresh_token_hash")
  status           SessionStatus @default(ACTIVE)
  expiresAt        DateTime      @map("expires_at")
  revokedAt        DateTime?     @map("revoked_at")
  revokeReason     String?       @map("revoke_reason")
  ipAddress        String?       @map("ip_address")
  userAgent        String?       @map("user_agent")
  lastUsedAt       DateTime      @map("last_used_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  user       User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, status])
  @@index([membershipId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
  @@map("sessions")
}

// ─── Delivery bounded context (owned by delivery module) — ADR-027–031 ───────

enum DeliveryStatus {
  DRAFT
  PLANNED
  READY_FOR_DISPATCH
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  PROBLEM
  CANCELLED
}

enum DeliveryMethod {
  OWN_COURIER
  TAXI
  THIRD_PARTY_SERVICE
}

enum GeocodingStatus {
  NOT_REQUESTED
  PENDING
  RESOLVED
  FAILED
  MANUAL
}

enum AddressSource {
  MANUAL
  GEOCODED
  USER_PIN
}

enum CourierStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeliveryProblemType {
  RECIPIENT_UNAVAILABLE
  WRONG_ADDRESS
  DELAY
  DAMAGED_ORDER
  PAYMENT_ISSUE
  COURIER_ISSUE
  OTHER
}

enum DeliveryProblemStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum DeliveryTimelineEventType {
  DELIVERY_CREATED
  DELIVERY_PLANNED
  ADDRESS_UPDATED
  COORDINATES_RESOLVED
  COORDINATES_SET_MANUALLY
  COURIER_ASSIGNED
  COURIER_REASSIGNED
  COURIER_RELEASED
  READY_FOR_DISPATCH
  HANDED_OVER
  IN_TRANSIT
  PROBLEM_REPORTED
  PROBLEM_RESOLVED
  DELIVERED
  CANCELLED
  ROUTE_ASSIGNED
  ROUTE_ORDER_CHANGED
}

enum RoutePlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

model DeliveryJob {
  id                    String          @id @default(uuid()) @db.Uuid
  organizationId        String          @map("organization_id") @db.Uuid
  storeId               String          @map("store_id") @db.Uuid
  orderId               String          @map("order_id") @db.Uuid
  number                String
  status                DeliveryStatus  @default(DRAFT)
  method                DeliveryMethod  @map("method")
  deliveryDate          DateTime        @map("delivery_date") @db.Date
  windowStart           DateTime        @map("window_start")
  windowEnd             DateTime        @map("window_end")
  requiredDispatchAt    DateTime?       @map("required_dispatch_at")
  recipientName         String          @map("recipient_name")
  recipientPhone        String          @map("recipient_phone")
  displayAddress        String          @map("display_address")
  addressLine           String          @map("address_line")
  city                  String
  postalCode            String?         @map("postal_code")
  entrance              String?
  floor                 String?
  apartment             String?
  accessCode            String?         @map("access_code")
  deliveryComment       String?         @map("delivery_comment")
  latitude              Decimal?        @db.Decimal(10, 7)
  longitude             Decimal?        @db.Decimal(10, 7)
  geocodingStatus       GeocodingStatus @default(NOT_REQUESTED) @map("geocoding_status")
  addressSource         AddressSource?  @map("address_source")
  deliveryFee           Decimal         @default(0) @map("delivery_fee") @db.Decimal(18, 2)
  currencyCode          String          @default("BYN") @map("currency_code") @db.Char(3)
  assignedCourierId     String?         @map("assigned_courier_id") @db.Uuid
  externalReference     String?         @map("external_reference")
  providerName          String?         @map("provider_name")
  handedOverAt          DateTime?       @map("handed_over_at")
  departedAt            DateTime?       @map("departed_at")
  deliveredAt           DateTime?       @map("delivered_at")
  cancelledAt           DateTime?       @map("cancelled_at")
  version               Int             @default(1)
  createdByMembershipId String?         @map("created_by_membership_id") @db.Uuid
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  assignedCourier CourierProfile?   @relation(fields: [assignedCourierId], references: [id], onDelete: Restrict)
  assignments  DeliveryAssignment[]
  problems     DeliveryProblem[]
  timeline     DeliveryTimelineEvent[]
  routeStops   DeliveryRouteStop[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, storeId])
  @@index([organizationId, storeId, status])
  @@index([organizationId, storeId, deliveryDate])
  @@index([organizationId, assignedCourierId])
  @@index([organizationId, storeId, windowStart])
  @@index([organizationId, storeId, requiredDispatchAt])
  @@index([orderId])
  @@map("delivery_jobs")
}

model DeliveryAssignment {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  deliveryJobId    String    @map("delivery_job_id") @db.Uuid
  courierProfileId String    @map("courier_profile_id") @db.Uuid
  assignedByMembershipId String? @map("assigned_by_membership_id") @db.Uuid
  assignedAt       DateTime  @map("assigned_at")
  releasedAt       DateTime? @map("released_at")
  releaseReason    String?   @map("release_reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  deliveryJob    DeliveryJob   @relation(fields: [deliveryJobId], references: [id], onDelete: Restrict)
  courierProfile CourierProfile @relation(fields: [courierProfileId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([deliveryJobId])
  @@index([courierProfileId])
  @@map("delivery_assignments")
}

model DeliveryProblem {
  id                    String                @id @default(uuid()) @db.Uuid
  organizationId        String                @map("organization_id") @db.Uuid
  deliveryJobId         String                @map("delivery_job_id") @db.Uuid
  type                  DeliveryProblemType
  description           String
  status                DeliveryProblemStatus @default(OPEN)
  reportedByMembershipId String?              @map("reported_by_membership_id") @db.Uuid
  reportedAt            DateTime              @map("reported_at")
  resolvedByMembershipId String?              @map("resolved_by_membership_id") @db.Uuid
  resolvedAt            DateTime?             @map("resolved_at")
  resolution            String?
  resolveToStatus       DeliveryStatus?       @map("resolve_to_status")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  deliveryJob  DeliveryJob  @relation(fields: [deliveryJobId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([deliveryJobId, status])
  @@map("delivery_problems")
}

model DeliveryTimelineEvent {
  id                    String                     @id @default(uuid()) @db.Uuid
  organizationId        String                     @map("organization_id") @db.Uuid
  deliveryJobId         String                     @map("delivery_job_id") @db.Uuid
  type                  DeliveryTimelineEventType
  message               String?
  actorMembershipId     String?                    @map("actor_membership_id") @db.Uuid
  payload               Json?
  occurredAt            DateTime                   @map("occurred_at")
  createdAt             DateTime                   @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  deliveryJob  DeliveryJob  @relation(fields: [deliveryJobId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([deliveryJobId, occurredAt])
  @@map("delivery_timeline_events")
}

model CourierProfile {
  id                   String        @id @default(uuid()) @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  membershipId         String        @map("membership_id") @db.Uuid
  displayNameSnapshot  String        @map("display_name_snapshot")
  phoneSnapshot        String?       @map("phone_snapshot")
  status               CourierStatus @default(ACTIVE)
  vehicleType          String?       @map("vehicle_type")
  vehicleDescription   String?       @map("vehicle_description")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignments  DeliveryAssignment[]
  deliveryJobs DeliveryJob[]
  routePlans   DeliveryRoutePlan[]

  @@unique([organizationId, membershipId])
  @@index([organizationId, status])
  @@map("courier_profiles")
}

model DeliveryRoutePlan {
  id                    String          @id @default(uuid()) @db.Uuid
  organizationId        String          @map("organization_id") @db.Uuid
  storeId               String          @map("store_id") @db.Uuid
  serviceDate           DateTime        @map("service_date") @db.Date
  courierProfileId      String?         @map("courier_profile_id") @db.Uuid
  name                  String
  status                RoutePlanStatus @default(DRAFT)
  version               Int             @default(1)
  createdByMembershipId String?         @map("created_by_membership_id") @db.Uuid
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store          Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  courierProfile CourierProfile?    @relation(fields: [courierProfileId], references: [id], onDelete: Restrict)
  stops          DeliveryRouteStop[]

  @@index([organizationId, storeId, serviceDate])
  @@index([organizationId, storeId, status])
  @@index([courierProfileId])
  @@map("delivery_route_plans")
}

model DeliveryRouteStop {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  routePlanId      String    @map("route_plan_id") @db.Uuid
  deliveryJobId    String    @map("delivery_job_id") @db.Uuid
  sequence         Int
  plannedArrivalAt DateTime? @map("planned_arrival_at")
  note             String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  routePlan    DeliveryRoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Restrict)
  deliveryJob  DeliveryJob       @relation(fields: [deliveryJobId], references: [id], onDelete: Restrict)

  @@unique([routePlanId, sequence])
  @@index([organizationId])
  @@index([deliveryJobId])
  @@map("delivery_route_stops")
}
