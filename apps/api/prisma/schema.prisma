generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WarehouseType {
  STORE
}

enum MasterDataStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ItemType {
  FLOWER
  MATERIAL
}

enum TrackingMethod {
  LOT
  NONE
}

// ─── Organization bounded context (owned by organization module) ─────────────

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  stores            Store[]
  warehouses        Warehouse[]
  auditLogs         AuditLog[]
  suppliers         Supplier[]
  itemCategories    ItemCategory[]
  unitsOfMeasure    UnitOfMeasure[]
  inventoryPolicies InventoryPolicy[]
  items             Item[]
  supplies          Supply[]
  supplyItems       SupplyItem[]
  goodsReceipts     GoodsReceipt[]
  goodsReceiptItems GoodsReceiptItem[]
  inventoryBatches  InventoryBatch[]
  inventoryMovements InventoryMovement[]
  inventoryBalances InventoryBalance[]
  postingIdempotencyKeys PostingIdempotencyKey[]
  inventoryReservations InventoryReservation[]
  reservationMovements ReservationMovement[]
  orders Order[]
  customers Customer[]
  orderCompositions OrderComposition[]
  orderCompositionItems OrderCompositionItem[]
  actualCompositions ActualComposition[]
  actualCompositionItems ActualCompositionItem[]
  orderAssignments OrderAssignment[]
  orderCompositionReplacements OrderCompositionReplacement[]
  orderTimelineEvents OrderTimelineEvent[]
  orderComments OrderComment[]
  sales Sale[]
  saleLines SaleLine[]
  saleDiscounts SaleDiscount[]
  saleInventoryConsumptions SaleInventoryConsumption[]
  saleInventoryConsumptionLines SaleInventoryConsumptionLine[]
  saleTimelineEvents SaleTimelineEvent[]
  saleAnnulments SaleAnnulment[]
  paymentMethods PaymentMethod[]
  payments Payment[]
  paymentAllocations PaymentAllocation[]
  paymentAllocationTransfers PaymentAllocationTransfer[]
  paymentRefunds PaymentRefund[]
  paymentTimelineEvents PaymentTimelineEvent[]
  cashAccounts CashAccount[]
  cashOperations CashOperation[]
  deliveryJobs DeliveryJob[]
  deliveryAssignments DeliveryAssignment[]
  deliveryProblems DeliveryProblem[]
  deliveryTimelineEvents DeliveryTimelineEvent[]
  courierProfiles CourierProfile[]
  deliveryRoutePlans DeliveryRoutePlan[]
  deliveryRouteStops DeliveryRouteStop[]
  writeOffDocuments WriteOffDocument[]
  writeOffItems WriteOffItem[]
  inventoryCounts InventoryCount[]
  inventoryCountItems InventoryCountItem[]
  transferDocuments TransferDocument[]
  transferItems TransferItem[]
  transferAllocations TransferAllocation[]
  transferTimelineEvents TransferTimelineEvent[]
  memberships        OrganizationMembership[]
  roles              Role[]

  @@index([status])
  @@map("organizations")
}

model Store {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  name           String
  code           String
  address        String?
  timezone       String      @default("Europe/Moscow")
  status         StoreStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouses   Warehouse[]
  auditLogs    AuditLog[]
  supplies     Supply[]
  goodsReceipts GoodsReceipt[]
  inventoryBatches InventoryBatch[]
  inventoryMovements InventoryMovement[]
  inventoryBalances InventoryBalance[]
  userStoreAccess   UserStoreAccess[]
  orders            Order[]
  inventoryReservations InventoryReservation[]
  reservationMovements ReservationMovement[]
  sales             Sale[]
  cashAccounts      CashAccount[]
  payments          Payment[]
  paymentRefunds    PaymentRefund[]
  cashOperations    CashOperation[]
  deliveryJobs      DeliveryJob[]
  deliveryRoutePlans DeliveryRoutePlan[]
  writeOffDocuments WriteOffDocument[]
  inventoryCounts InventoryCount[]
  transferDocuments TransferDocument[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("stores")
}

model Warehouse {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  storeId        String          @map("store_id") @db.Uuid
  name           String
  code           String
  type           WarehouseType   @default(STORE)
  isDefault      Boolean         @default(false) @map("is_default")
  status         WarehouseStatus @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  supplies     Supply[]
  goodsReceipts GoodsReceipt[]
  inventoryBatches InventoryBatch[]
  inventoryMovements InventoryMovement[]
  inventoryBalances InventoryBalance[]
  orders Order[]
  inventoryReservations InventoryReservation[]
  reservationMovements ReservationMovement[]
  sales Sale[]
  writeOffDocuments WriteOffDocument[]
  inventoryCounts InventoryCount[]
  transferDocumentsFrom TransferDocument[] @relation("TransferFromWarehouse")
  transferDocumentsTo TransferDocument[] @relation("TransferToWarehouse")

  @@unique([storeId, code])
  @@index([organizationId])
  @@index([storeId])
  @@index([organizationId, status])
  @@map("warehouses")
}

// ─── Audit (owned by platform/audit — append-only) ───────────────────────────

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  storeId        String?  @map("store_id") @db.Uuid
  actorId        String?  @map("actor_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  beforeState    Json?    @map("before_state")
  afterState     Json?    @map("after_state")
  reason         String?
  requestId      String   @map("request_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store?       @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@index([storeId])
  @@index([requestId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Master Data bounded context (owned by master-data module) ───────────────

model Supplier {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  name           String
  code           String
  country        String?
  phone          String?
  email          String?
  contactPerson  String?          @map("contact_person")
  comment        String?
  status         MasterDataStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  supplies     Supply[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
  @@map("suppliers")
}

model ItemCategory {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  name           String
  code           String
  parentId       String?          @map("parent_id") @db.Uuid
  status         MasterDataStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent       ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children     ItemCategory[] @relation("CategoryTree")
  items        Item[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([parentId])
  @@map("item_categories")
}

model UnitOfMeasure {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  name           String
  symbol         String
  /// 0 = integers only; 1–3 = allowed fractional digits (ADR-011)
  quantityScale  Int              @default(0) @map("quantity_scale")
  status         MasterDataStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  items        Item[]

  @@unique([organizationId, symbol])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("units_of_measure")
}

model InventoryPolicy {
  id                   String           @id @default(uuid()) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  name                 String
  itemType             ItemType         @map("item_type")
  trackingMethod       TrackingMethod   @map("tracking_method")
  reservationAllowed   Boolean          @default(false) @map("reservation_allowed")
  expirationTracking   Boolean          @map("expiration_tracking")
  defaultShelfLifeDays Int?             @map("default_shelf_life_days")
  /// System preset: FLOWER_DEFAULT | MATERIAL_UNIT | MATERIAL_FRACTIONAL | null = custom
  presetCode           String?          @map("preset_code")
  status               MasterDataStatus @default(ACTIVE)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  items        Item[]

  @@unique([organizationId, presetCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, itemType])
  @@map("inventory_policies")
}

model Item {
  id                String           @id @default(uuid()) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  categoryId        String           @map("category_id") @db.Uuid
  unitId            String           @map("unit_id") @db.Uuid
  inventoryPolicyId String           @map("inventory_policy_id") @db.Uuid
  name              String
  code              String
  itemType          ItemType         @map("item_type")
  description       String?
  isPurchasable     Boolean          @default(true) @map("is_purchasable")
  isSellable        Boolean          @default(false) @map("is_sellable")
  status            MasterDataStatus @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  category        ItemCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unit            UnitOfMeasure   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  inventoryPolicy InventoryPolicy @relation(fields: [inventoryPolicyId], references: [id], onDelete: Restrict)
  supplyItems     SupplyItem[]
  receiptItems    GoodsReceiptItem[]
  batches         InventoryBatch[]
  movements       InventoryMovement[]
  balances        InventoryBalance[]
  orderCompositionItems OrderCompositionItem[]
  actualCompositionItems ActualCompositionItem[]
  compositionReplacementsFrom OrderCompositionReplacement[] @relation("CompositionReplacementFromItem")
  compositionReplacementsTo   OrderCompositionReplacement[] @relation("CompositionReplacementToItem")
  reservations    InventoryReservation[]
  reservationMovements ReservationMovement[]
  writeOffItems   WriteOffItem[]
  inventoryCountItems InventoryCountItem[]
  transferItems   TransferItem[]
  transferAllocationsFrom TransferAllocation[] @relation("TransferAllocationFromItem")
  transferAllocationsTo   TransferAllocation[] @relation("TransferAllocationToItem")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, itemType])
  @@index([organizationId, categoryId])
  @@index([organizationId, name])
  @@index([unitId])
  @@index([inventoryPolicyId])
  @@map("items")
}

// ─── Supply bounded context (owned by supply module) ─────────────────────────

enum SupplyStatus {
  DRAFT
  SUBMITTED_TO_SUPPLIER
  PARTIALLY_RECEIVED
  RECEIVED
  ANNULLED
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
  REVERSED
}

model Supply {
  id                  String       @id @default(uuid()) @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  storeId             String       @map("store_id") @db.Uuid
  warehouseId         String       @map("warehouse_id") @db.Uuid
  supplierId          String       @map("supplier_id") @db.Uuid
  number              String
  status              SupplyStatus @default(DRAFT)
  submittedAt         DateTime?    @map("submitted_at")
  expectedReceiptDate DateTime?    @map("expected_receipt_date") @db.Date
  comment             String?
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  supplier     Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items        SupplyItem[]
  receipts     GoodsReceipt[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, storeId])
  @@index([organizationId, status])
  @@index([supplierId])
  @@map("supplies")
}

model SupplyItem {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  supplyId          String   @map("supply_id") @db.Uuid
  itemId            String   @map("item_id") @db.Uuid
  orderedQuantity   Decimal  @map("ordered_quantity") @db.Decimal(18, 3)
  plannedUnitPrice  Decimal? @map("planned_unit_price") @db.Decimal(18, 4)
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  supply       Supply            @relation(fields: [supplyId], references: [id], onDelete: Restrict)
  item         Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  receiptItems GoodsReceiptItem[]

  @@unique([supplyId, itemId])
  @@index([organizationId])
  @@index([supplyId])
  @@index([itemId])
  @@map("supply_items")
}

model GoodsReceipt {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  storeId        String             @map("store_id") @db.Uuid
  warehouseId    String             @map("warehouse_id") @db.Uuid
  supplyId       String             @map("supply_id") @db.Uuid
  number         String
  status         GoodsReceiptStatus @default(DRAFT)
  receivedAt     DateTime           @map("received_at")
  postedAt       DateTime?          @map("posted_at")
  comment        String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  supply       Supply             @relation(fields: [supplyId], references: [id], onDelete: Restrict)
  items        GoodsReceiptItem[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, storeId])
  @@index([supplyId])
  @@index([organizationId, status])
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id                String  @id @default(uuid()) @db.Uuid
  organizationId    String  @map("organization_id") @db.Uuid
  goodsReceiptId    String  @map("goods_receipt_id") @db.Uuid
  supplyItemId      String  @map("supply_item_id") @db.Uuid
  itemId            String  @map("item_id") @db.Uuid
  receivedQuantity  Decimal @map("received_quantity") @db.Decimal(18, 3)
  acceptedQuantity  Decimal @map("accepted_quantity") @db.Decimal(18, 3)
  defectiveQuantity Decimal @map("defective_quantity") @db.Decimal(18, 3)
  actualUnitPrice   Decimal @map("actual_unit_price") @db.Decimal(18, 4)
  defectReason      String? @map("defect_reason")
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  goodsReceipt GoodsReceipt     @relation(fields: [goodsReceiptId], references: [id], onDelete: Restrict)
  supplyItem   SupplyItem       @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)
  item         Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch        InventoryBatch?

  @@unique([goodsReceiptId, supplyItemId])
  @@index([organizationId])
  @@index([goodsReceiptId])
  @@index([supplyItemId])
  @@index([itemId])
  @@map("goods_receipt_items")
}

// ─── Inventory bounded context (owned by inventory module) ───────────────────

enum InventoryBatchStatus {
  ACTIVE
  DEPLETED
  REVERSED
}

enum InventoryBatchSourceType {
  GOODS_RECEIPT
  TRANSFER_IN
  COUNT_ADJUSTMENT
}

enum InventoryMovementType {
  RECEIPT
  RECEIPT_REVERSAL
  ISSUE
  ISSUE_REVERSAL
  WRITE_OFF
  WRITE_OFF_REVERSAL
  TRANSFER_OUT
  TRANSFER_OUT_REVERSAL
  TRANSFER_IN
  TRANSFER_IN_REVERSAL
  COUNT_ADJUSTMENT_OUT
  COUNT_ADJUSTMENT_IN
}

model InventoryBatch {
  id                 String               @id @default(uuid()) @db.Uuid
  organizationId     String               @map("organization_id") @db.Uuid
  storeId            String               @map("store_id") @db.Uuid
  warehouseId        String               @map("warehouse_id") @db.Uuid
  itemId             String               @map("item_id") @db.Uuid
  goodsReceiptItemId String?              @unique @map("goods_receipt_item_id") @db.Uuid
  batchSourceType    InventoryBatchSourceType @default(GOODS_RECEIPT) @map("batch_source_type")
  transferAllocationId String?            @unique @map("transfer_allocation_id") @db.Uuid
  inventoryCountItemId String?            @unique @map("inventory_count_item_id") @db.Uuid
  receivedAt         DateTime             @map("received_at")
  initialQuantity    Decimal              @map("initial_quantity") @db.Decimal(18, 3)
  remainingQuantity  Decimal              @map("remaining_quantity") @db.Decimal(18, 3)
  unitCost           Decimal              @map("unit_cost") @db.Decimal(18, 4)
  expiresAt          DateTime?            @map("expires_at") @db.Date
  status             InventoryBatchStatus @default(ACTIVE)
  createdAt          DateTime             @default(now()) @map("created_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  item             Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  goodsReceiptItem     GoodsReceiptItem? @relation(fields: [goodsReceiptItemId], references: [id], onDelete: Restrict)
  transferAllocation   TransferAllocation? @relation("TransferInboundBatch", fields: [transferAllocationId], references: [id], onDelete: Restrict)
  inventoryCountItem   InventoryCountItem? @relation("CountAdjustmentBatch", fields: [inventoryCountItemId], references: [id], onDelete: Restrict)
  transferSourceAllocations TransferAllocation[] @relation("TransferSourceBatch")
  movements        InventoryMovement[]
  reservations     InventoryReservation[]
  reservationMovements ReservationMovement[]

  @@index([organizationId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, itemId])
  @@index([organizationId, status])
  @@map("inventory_batches")
}

model InventoryMovement {
  id                    String                @id @default(uuid()) @db.Uuid
  organizationId        String                @map("organization_id") @db.Uuid
  storeId               String                @map("store_id") @db.Uuid
  warehouseId           String                @map("warehouse_id") @db.Uuid
  itemId                String                @map("item_id") @db.Uuid
  batchId               String?               @map("batch_id") @db.Uuid
  type                  InventoryMovementType
  quantity              Decimal               @db.Decimal(18, 3)
  unitCost              Decimal?              @map("unit_cost") @db.Decimal(18, 4)
  sourceDocumentType    String                @map("source_document_type")
  sourceDocumentId      String                @map("source_document_id") @db.Uuid
  sourceDocumentItemId  String                @map("source_document_item_id") @db.Uuid
  reversalOfMovementId  String?               @map("reversal_of_movement_id") @db.Uuid
  occurredAt            DateTime              @map("occurred_at")
  createdAt             DateTime              @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  item         Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  batch        InventoryBatch? @relation(fields: [batchId], references: [id], onDelete: Restrict)
  reversalOf   InventoryMovement?  @relation("MovementReversal", fields: [reversalOfMovementId], references: [id], onDelete: Restrict)
  reversals    InventoryMovement[] @relation("MovementReversal")

  @@unique([organizationId, sourceDocumentType, sourceDocumentItemId, type])
  @@index([organizationId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, itemId])
  @@index([sourceDocumentId])
  @@index([batchId])
  @@index([occurredAt])
  @@map("inventory_movements")
}

model InventoryBalance {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  storeId           String   @map("store_id") @db.Uuid
  warehouseId       String   @map("warehouse_id") @db.Uuid
  itemId            String   @map("item_id") @db.Uuid
  onHandQuantity    Decimal  @map("on_hand_quantity") @db.Decimal(18, 3)
  reservedQuantity  Decimal  @default(0) @map("reserved_quantity") @db.Decimal(18, 3)
  availableQuantity Decimal  @map("available_quantity") @db.Decimal(18, 3)
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([organizationId, storeId, warehouseId, itemId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, itemId])
  @@map("inventory_balances")
}

model PostingIdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  scope          String
  key            String
  documentId     String   @map("document_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, scope, key])
  @@index([organizationId, documentId])
  @@map("posting_idempotency_keys")
}

// ─── Orders bounded context (owned by orders module) — ADR-015 ───────────────

enum OrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RESERVED
  RESERVED
  IN_PREPARATION
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum OrderOccasion {
  BIRTHDAY
  WEDDING
  ROMANTIC
  CORPORATE
  FUNERAL
  MOTHER_DAY
  NEW_YEAR
  OTHER
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

enum OrderTimelineEventType {
  ORDER_CREATED
  CONFIRMED
  RESERVATION_SUCCEEDED
  RESERVATION_PARTIAL
  RESERVATION_FAILED
  PREPARATION_STARTED
  COMPOSITION_CHANGED
  ACTUAL_COMPOSITION_CHANGED
  COMPOSITION_REPLACED
  READY
  COMPLETED
  CANCELLED
  ASSIGNMENT_CHANGED
  COMMENT_ADDED
  REFERENCE_UPDATED
  SALE_COMPLETED
  SALE_ANNULLED
  PAYMENT_RECEIVED
  DELIVERY_CREATED
  DELIVERY_COMPLETED
  DELIVERY_CANCELLED
}

enum CompositionReplacementReason {
  OUT_OF_STOCK
  QUALITY
  CUSTOMER_REQUEST
  FLORIST_DECISION
  OTHER
}

model Customer {
  id                 String         @id @default(uuid()) @db.Uuid
  organizationId     String         @map("organization_id") @db.Uuid
  name               String
  phone              String
  email              String?
  notes              String?
  preferredLanguage  String?        @map("preferred_language")
  status             CustomerStatus @default(ACTIVE)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  orders       Order[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
  @@map("customers")
}

model Order {
  id                   String         @id @default(uuid()) @db.Uuid
  organizationId       String         @map("organization_id") @db.Uuid
  storeId              String         @map("store_id") @db.Uuid
  warehouseId          String         @map("warehouse_id") @db.Uuid
  customerId           String?        @map("customer_id") @db.Uuid
  number               String
  status               OrderStatus    @default(DRAFT)
  type                 OrderType      @default(PICKUP)
  occasion             OrderOccasion  @default(OTHER)
  orderDate            DateTime       @default(now()) @map("order_date") @db.Date
  readyAt              DateTime?      @map("ready_at")
  /// Snapshot — not live Customer fields
  customerNameSnapshot String?        @map("customer_name_snapshot")
  customerPhoneSnapshot String?       @map("customer_phone_snapshot")
  recipientName        String?        @map("recipient_name")
  recipientPhone       String?        @map("recipient_phone")
  comment              String?
  referenceUrl         String?        @map("reference_url")
  referenceComment     String?        @map("reference_comment")
  plannedPrice         Decimal?       @map("planned_price") @db.Decimal(18, 2)
  assignedFloristId    String?        @map("assigned_florist_id") @db.Uuid
  createdByMembershipId String?       @map("created_by_membership_id") @db.Uuid
  /// Optimistic concurrency for actual-composition / prep mutations (ADR-024)
  version              Int            @default(1) @map("version")
  confirmedAt          DateTime?      @map("confirmed_at")
  reservedAt           DateTime?      @map("reserved_at")
  preparationStartedAt DateTime?      @map("preparation_started_at")
  completedAt          DateTime?      @map("completed_at")
  cancelledAt          DateTime?      @map("cancelled_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  composition  OrderComposition?
  actualComposition ActualComposition?
  assignments  OrderAssignment[]
  compositionReplacements OrderCompositionReplacement[]
  timeline     OrderTimelineEvent[]
  comments     OrderComment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, storeId])
  @@index([organizationId, status])
  @@index([organizationId, storeId, readyAt])
  @@index([organizationId, storeId, orderDate])
  @@index([customerId])
  @@index([assignedFloristId])
  @@map("orders")
}

model OrderComposition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  items        OrderCompositionItem[]

  @@index([organizationId])
  @@map("order_compositions")
}

model OrderCompositionItem {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  compositionId    String   @map("composition_id") @db.Uuid
  itemId           String   @map("item_id") @db.Uuid
  plannedQuantity  Decimal  @map("planned_quantity") @db.Decimal(18, 3)
  comment          String?
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  composition  OrderComposition @relation(fields: [compositionId], references: [id], onDelete: Restrict)
  item         Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([compositionId, itemId])
  @@index([organizationId])
  @@index([compositionId])
  @@index([itemId])
  @@map("order_composition_items")
}

model ActualComposition {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  orderId        String    @unique @map("order_id") @db.Uuid
  frozenAt       DateTime? @map("frozen_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order                   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  items        ActualCompositionItem[]

  @@index([organizationId])
  @@map("actual_compositions")
}

model ActualCompositionItem {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  compositionId  String   @map("composition_id") @db.Uuid
  itemId         String   @map("item_id") @db.Uuid
  actualQuantity Decimal  @map("actual_quantity") @db.Decimal(18, 3)
  /// Opaque batch id from inventory allocation — orders never query Batch tables
  batchId        String?  @map("batch_id") @db.Uuid
  comment        String?
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  composition  ActualComposition @relation(fields: [compositionId], references: [id], onDelete: Restrict)
  item         Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([compositionId])
  @@index([itemId])
  @@map("actual_composition_items")
}

model OrderAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  orderId        String    @map("order_id") @db.Uuid
  membershipId   String    @map("membership_id") @db.Uuid
  assignedAt     DateTime  @map("assigned_at")
  releasedAt     DateTime? @map("released_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([orderId])
  @@index([membershipId])
  @@index([orderId, releasedAt])
  /// Partial unique one-active-per-order enforced in SQL:
  /// CREATE UNIQUE INDEX ... ON order_assignments(order_id) WHERE released_at IS NULL
  @@map("order_assignments")
}

/// Structured actual-composition item replacement (not timeline-only). Owned by orders.
model OrderCompositionReplacement {
  id                 String                       @id @default(uuid()) @db.Uuid
  organizationId     String                       @map("organization_id") @db.Uuid
  orderId            String                       @map("order_id") @db.Uuid
  fromItemId         String                       @map("from_item_id") @db.Uuid
  toItemId           String                       @map("to_item_id") @db.Uuid
  quantity           Decimal                      @db.Decimal(18, 3)
  reason             CompositionReplacementReason
  comment            String?
  actorMembershipId  String?                      @map("actor_membership_id") @db.Uuid
  createdAt          DateTime                     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  fromItem     Item         @relation("CompositionReplacementFromItem", fields: [fromItemId], references: [id], onDelete: Restrict)
  toItem       Item         @relation("CompositionReplacementToItem", fields: [toItemId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([orderId, createdAt])
  @@index([fromItemId])
  @@index([toItemId])
  @@map("order_composition_replacements")
}

model OrderTimelineEvent {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  orderId        String                 @map("order_id") @db.Uuid
  type           OrderTimelineEventType
  message        String?
  actorMembershipId String?             @map("actor_membership_id") @db.Uuid
  payload        Json?
  occurredAt     DateTime               @map("occurred_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([orderId, occurredAt])
  @@map("order_timeline_events")
}

model OrderComment {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  orderId           String   @map("order_id") @db.Uuid
  authorMembershipId String  @map("author_membership_id") @db.Uuid
  message           String
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([orderId, createdAt])
  @@map("order_comments")
}

// ─── Inventory reservations (owned by inventory module) ───────────────────────

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

enum ReservationMovementType {
  RESERVE
  RELEASE
  CONSUME
}

model InventoryReservation {
  id             String                     @id @default(uuid()) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  storeId        String                     @map("store_id") @db.Uuid
  warehouseId    String                     @map("warehouse_id") @db.Uuid
  itemId         String                     @map("item_id") @db.Uuid
  batchId        String                     @map("batch_id") @db.Uuid
  /// Opaque source — OrderCompositionItem.id (ADR-015)
  orderItemId    String                     @map("order_item_id") @db.Uuid
