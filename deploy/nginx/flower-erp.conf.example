# Flower ERP — reverse proxy snippet (add to existing nginx on VPS)
#
# Does NOT bind 80/443 here — include inside your existing server {} blocks.
# Replace domains and SSL paths with your certificates.
# ORVIX config is untouched; this is an additive include only.
#
# Install:
#   sudo cp deploy/nginx/flower-erp.conf.example /etc/nginx/snippets/flower-erp.conf
#   # Add to your existing server block:
#   #   include snippets/flower-erp.conf;
#   sudo nginx -t && sudo systemctl reload nginx

# ── Backoffice (Next.js) ──────────────────────────────────────────────────────
# server {
#   listen 443 ssl http2;
#   server_name flower.example.com;
#   include /etc/letsencrypt/options-ssl-nginx.conf;
#   ssl_certificate     /etc/letsencrypt/live/flower.example.com/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/flower.example.com/privkey.pem;
#
#   include snippets/flower-erp-backoffice.conf;
# }

upstream flower_backoffice {
    server 127.0.0.1:3100;
    keepalive 8;
}

upstream flower_api {
    server 127.0.0.1:4100;
    keepalive 8;
}

# Backoffice UI
location / {
    proxy_pass http://flower_backoffice;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;
}

# ── API (NestJS) — separate subdomain recommended ───────────────────────────────
# server {
#   listen 443 ssl http2;
#   server_name flower-api.example.com;
#   ...
#   include snippets/flower-erp-api.conf;
# }

location /api/v1/ {
    proxy_pass http://flower_api;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_send_timeout 120s;
    client_max_body_size 2m;
}

# Health check (optional, restrict by IP or internal use)
location = /api/v1/health/live {
    proxy_pass http://flower_api;
    access_log off;
}

location = /api/v1/health/ready {
    proxy_pass http://flower_api;
    access_log off;
}
