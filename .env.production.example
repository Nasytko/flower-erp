# Flower ERP — production environment template
# Copy to /opt/flower-erp/.env.production and fill secrets.
# NEVER commit .env.production to git.

# ── Compose / image tags ──────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=flower-erp
FLOWER_API_IMAGE=flower-erp-api:production
FLOWER_MIGRATE_IMAGE=flower-erp-migrate:production
FLOWER_BACKOFFICE_IMAGE=flower-erp-backoffice:production

# Localhost-only bindings (reverse proxy on host uses these ports)
FLOWER_API_PORT=4100
FLOWER_BACKOFFICE_PORT=3100

# Resource limits (shared VPS — tune per available RAM/CPU)
FLOWER_API_CPUS=0.75
FLOWER_API_MEM_LIMIT=768m
FLOWER_API_MEM_RESERVATION=256m
FLOWER_BACKOFFICE_CPUS=0.50
FLOWER_BACKOFFICE_MEM_LIMIT=512m
FLOWER_BACKOFFICE_MEM_RESERVATION=128m

# ── Public URLs (used by backoffice build + CORS) ─────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api-erp.nasytko.ru/api/v1
CORS_ORIGINS=https://erp.nasytko.ru

# ── API runtime ───────────────────────────────────────────────────────────────
API_PREFIX=api/v1
LOG_LEVEL=info
BODY_LIMIT=1mb
SWAGGER_ENABLED=false
SWAGGER_PATH=docs

# Runtime DML role (least privilege — used by API container)
DATABASE_URL=postgresql://flower_user:CHANGE_ME@leadflow-postgres-1:5432/flower_erp?schema=public

# DDL role (migrations only — used by migrate job)
DATABASE_MIGRATE_URL=postgresql://flower_migrate:CHANGE_ME@leadflow-postgres-1:5432/flower_erp?schema=public

# ── Auth secrets (generate: openssl rand -base64 48) ──────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=14
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
ALLOW_OWNER_BOOTSTRAP=false

# ── Backup scripts (host-side pg_dump; not used by containers) ─────────────────
FLOWER_DB_HOST=leadflow-postgres-1
FLOWER_DB_PORT=5432
FLOWER_DB_NAME=flower_erp
FLOWER_DB_USER=flower_user
# Set in .env.production only — never commit:
# FLOWER_DB_PASSWORD=
# FLOWER_DB_BACKUP_DIR=/opt/flower-erp/backups

# ── Future external DBaaS migration ───────────────────────────────────────────
# Replace DATABASE_URL and DATABASE_MIGRATE_URL with provider connection strings, e.g.:
# DATABASE_URL=postgresql://flower_user:CHANGE_ME@db.example.com:5432/flower_erp?sslmode=require
# DATABASE_MIGRATE_URL=postgresql://flower_migrate:CHANGE_ME@db.example.com:5432/flower_erp?sslmode=require
# Then: ./deploy/scripts/migrate.sh && docker compose ... up -d --force-recreate api
