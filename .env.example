# Flower ERP environment template — no real secrets.
# Copy to .env and replace values locally. Never commit .env.

NODE_ENV=development

# --- API ---
PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
BODY_LIMIT=1mb
LOG_LEVEL=info

# Runtime DB user (DML). Least privilege in deployed environments.
DATABASE_URL=postgresql://flower:flower@localhost:5432/flower_erp?schema=public

# Migration DB user (DDL). Use a separate role in production.
DATABASE_MIGRATE_URL=postgresql://flower:flower@localhost:5432/flower_erp?schema=public

# OpenAPI / Swagger — disabled unless explicitly true (keep false in production)
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- Auth (API) ---
JWT_ACCESS_SECRET=local-dev-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=local-dev-refresh-secret-min-32-characters-long
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=14
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_LOGIN_PER_MINUTE=10
AUTH_RATE_LIMIT_REFRESH_PER_MINUTE=30
AUTH_COOKIE_SAME_SITE=lax
ALLOW_OWNER_BOOTSTRAP=false

# --- Backoffice ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=Flower ERP
